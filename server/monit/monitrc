set daemon 30 with start delay 5
set logfile syslog facility log_daemon
set idfile /var/lib/monit/id
set statefile /var/lib/monit/state
set httpd port 2812 and
    ssl enable
    pemfile /var/certs/monit.pem;
    allow localhost        # allow localhost to connect to the server
    allow 192.168.2.254    # self
    allow 192.168.2.1      # home net
    allow admin:monit_pass
    allow 192.168.2.127    # mac-13"
    allow 192.168.2.128    # mac-16"
    allow 192.168.10.2     # home 2 vpn
    allow 172.17.0.3       # docker wireguard
set eventqueue
    basedir /var/lib/monit/events
    slots 100
include /etc/monit/conf.d/*

set mail-format {
from: server_gmail
subject: 🛠  $EVENT
message: 

>  ⏰ $DATE
>  ⚙️  $ACTION
>  🍥 $HOST
$DESCRIPTION

©️ Monit }


set mailserver 127.0.0.1  with timeout 5 seconds
set alert my_gmail but not on { action, instance }
